{
  "name": "@unocss-applet/transformer-hover",
  "type": "module",
  "version": "0.13.6",
  "description": "Transform `hover:` utilities into the mini-program-native `hover-class` attribute for [UnoCSS](https://github.com/unocss/unocss).",
  "author": "Neil Lee <zguolee@foxmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/unocss-applet/unocss-applet/tree/main/packages/transformer-hover#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unocss-applet/unocss-applet.git",
    "directory": "packages/transformer-hover"
  },
  "bugs": "https://github.com/unocss-applet/unocss-applet/issues",
  "keywords": [
    "unocss",
    "unocss-transformer",
    "uni-app",
    "hover-class"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./*": "./*"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "build-post": "exit 0",
    "stub": "unbuild --stub"
  },
  "dependencies": {
    "@unocss/core": "catalog:unocss",
    "magic-string": "catalog:utils"
  }
}
